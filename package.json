{
	"name": "blissbase",
	"private": true,
	"version": "0.0.4",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "npm run test:run:ci && vite build",
		"test:run:ci": "if [ \"$VERCEL\" = \"1\" ]; then echo 'Skipping events.test.ts in Vercel environment due to PGlite array serialization issue'; vitest run --exclude='**/events.test.ts'; else npm run test:run; fi",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest --watch",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:all": "bun run test:run && bun run test:e2e",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:pull": "drizzle-kit pull",
		"scrape": "bun run scripts/scrape-websites.ts",
		"scrapeImport": "bun run scripts/import-events.ts",
		"deduplicateImages": "bun run scripts/deduplicate-images.ts",
		"cleanupUnusedImages": "bun run scripts/cleanup-unused-images.ts",
		"cleanupUnusedImages:dry": "bun run scripts/cleanup-unused-images.ts --dry-run",
		"analyze:vercel-functions": "node scripts/analyze-vercel-functions.mjs",
		"deploy:cf": "npx wrangler deploy --cwd blissbase-telegram-entry",
		"wuchale:clean": "wuchale --clean"
	},
	"devDependencies": {
		"@ai-sdk/google": "^3.0.63",
		"@ai-sdk/openai": "^3.0.53",
		"@electric-sql/pglite": "^0.4.4",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@iconify/json": "^2.2.462",
		"@iconify/tailwind4": "^1.2.3",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.12",
		"@types/cheerio": "^1.0.0",
		"@types/node": "^25.6.0",
		"@types/sharp": "^0.32.0",
		"@types/ws": "^8.18.1",
		"@vercel/functions": "^3.4.3",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@wuchale/svelte": "^0.19.3",
		"ai": "^6.0.161",
		"bits-ui": "^2.17.3",
		"calendar-link": "^2.11.0",
		"cheerio": "^1.2.0",
		"daisyui": "^5.5.19",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"postgres": "^3.4.9",
		"posthog-node": "^5.29.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rollup": "^4.60.1",
		"sharp": "^0.34.5",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svelte-meta-tags": "^4.6.0",
		"tailwindcss": "^4.2.2",
		"telegraf": "^4.16.3",
		"telegram": "^2.26.22",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2",
		"unplugin-icons": "^23.0.1",
		"valibot": "^1.3.1",
		"vite": "^8.0.8",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.4",
		"wuchale": "^0.22.9"
	},
	"dependencies": {
		"@bradenmacdonald/s3-lite-client": "npm:@jsr/bradenmacdonald__s3-lite-client@^0.9.6",
		"@editorjs/editorjs": "^2.31.6",
		"@editorjs/header": "^2.8.8",
		"@editorjs/list": "^2.0.9",
		"@editorjs/marker": "^1.4.0",
		"@editorjs/paragraph": "^2.11.7",
		"@internationalized/date": "^3.12.1",
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.103.0",
		"blockhash-core": "^0.1.0",
		"browser-image-compression": "^2.0.2",
		"drizzle-orm": "^0.45.2",
		"editorjs-html": "^4.0.5",
		"ky": "^2.0.1",
		"posthog-js": "^1.367.0",
		"svelte-dnd-action": "^0.9.69",
		"svelte-easy-crop": "^5.0.1",
		"svelte-sonner": "^1.1.0",
		"ws": "^8.20.0"
	}
}
